# Ignore files with no extention.
*
!*/
!*.*
!LICENSE

# Ignore hidden files, but not the license or github files.
.*
!.github/
!.github/**
!.gitignore

# Normal ignores.
*.exe
nimcache
*.pdb
*.ilk
*.out

# Project specific ignores.
build/
dist/
coverage/
docs/htmldocs/
tests/tmp/
tmp/
examples/data/*.glb
examples/emscripten/*.data
examples/emscripten/*.js
examples/emscripten/*.wasm
examples/emscripten/emscripten_damaged_helmet.html
